# Base de datos
DATABASE_URL="postgresql://postgres:password@localhost:5432/isp_instalaciones"

OLT_ENCRYPTION_KEY=tu-clave-secreta-aqui

# JWT
JWT_SECRET="cambia_esto_por_un_secreto_muy_largo_y_seguro"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV=development

# Almacenamiento de archivos (Cloudflare R2 o AWS S3)
STORAGE_TYPE=local           # local | s3 | r2
STORAGE_LOCAL_PATH=./uploads

# S3 / R2 (completar si STORAGE_TYPE=s3 o r2)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=                 # Solo para R2: https://<account>.r2.cloudflarestorage.com

# URLs
API_URL=http://localhost:3000


# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/isp_instalaciones?connection_limit=20&pool_timeout=10&connect_timeout=10"

# ── OLT ───────────────────────────────────────────────────────
OLT_ENCRYPTION_KEY=tu-clave-secreta-aqui-minimo-32-caracteres

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET="cambia_esto_por_un_secreto_muy_largo_y_seguro_minimo_64_caracteres"
JWT_EXPIRES_IN="7d"

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=https://tudominio.com

# ── Almacenamiento ────────────────────────────────────────────
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# S3 / R2 (completar si STORAGE_TYPE=s3 o r2)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ── URLs ──────────────────────────────────────────────────────
API_URL=https://tudominio.com

# ── OpenSSL (para OLTs ZTE legacy) ────────────────────────────
OPENSSL_CONF=./openssl.cnf